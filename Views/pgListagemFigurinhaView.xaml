<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetoAlbumCopa.Views.pgListagemFigurinhaView"
             Title="Lista de Figurinhas"
             BackgroundColor="#F4F4F9">

    <VerticalStackLayout Padding="15" Spacing="10">

        <Frame BackgroundColor="White" CornerRadius="8" Padding="10" HasShadow="True" BorderColor="#E0E0E0">
            <VerticalStackLayout Spacing="10">
                <Label Text="Filtros Combinados:" FontAttributes="Bold" TextColor="#1F1F1F"/>

                <Entry x:Name="txtBuscaNome" Placeholder="Buscar por nome..." PlaceholderColor="Gray" TextColor="Black" TextChanged="Filtro_Changed" BackgroundColor="#F4F4F9"/>

                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <Switch x:Name="swtFiltroAdquiridas" Toggled="Filtro_Changed" OnColor="#28A745"/>
                        <Label Text="Adquiridas" VerticalOptions="Center" TextColor="#1F1F1F"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <Switch x:Name="swtFiltroDesejadas" Toggled="Filtro_Changed" OnColor="#28A745"/>
                        <Label Text="Desejadas" VerticalOptions="Center" TextColor="#1F1F1F"/>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <ListView x:Name="ltvFigurinhas" HasUnevenRows="True" BackgroundColor="Transparent" Margin="0,10,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame BackgroundColor="White" CornerRadius="8" Margin="0,5,0,5" Padding="10" HasShadow="False" BorderColor="#E0E0E0">
                            <Grid ColumnDefinitions="80, *, Auto" RowDefinitions="Auto, Auto">

                                <Image Source="{Binding DirImagem}" WidthRequest="70" HeightRequest="70" Aspect="AspectFill" Grid.Column="0" Grid.RowSpan="2" VerticalOptions="Center"/>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                                    <Label Text="{Binding NomeJogador}" FontAttributes="Bold" FontSize="16" TextColor="#1F1F1F"/>
                                    <Label Text="{Binding Selecao}" FontSize="14" TextColor="#555555"/>
                                    <Label Text="{Binding Tipo}" FontSize="12" TextColor="#8A1538" FontAttributes="Italic"/>
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="2" Grid.RowSpan="2" Spacing="12" VerticalOptions="Center">

                                    <Image Source="icon_eye.png" WidthRequest="28" HeightRequest="28" VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="Eye_Tapped" />
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image WidthRequest="28" HeightRequest="28" VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="Check_Tapped" />
                                        </Image.GestureRecognizers>
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding Obtido}" Value="True">
                                                <Setter Property="Source" Value="icon_check_on.png" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding Obtido}" Value="False">
                                                <Setter Property="Source" Value="icon_check_off.png" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>

                                    <Image WidthRequest="28" HeightRequest="28" VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="Heart_Tapped" />
                                        </Image.GestureRecognizers>
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding Desejado}" Value="True">
                                                <Setter Property="Source" Value="icon_heart_on.png" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding Desejado}" Value="False">
                                                <Setter Property="Source" Value="icon_heart_off.png" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>

                                    <Image Source="icon_trash.png" WidthRequest="28" HeightRequest="28" VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="Trash_Tapped" />
                                        </Image.GestureRecognizers>
                                    </Image>

                                </HorizontalStackLayout>
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>
</ContentPage>