<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetoAlbumCopa.Views.pgCadFigurinhaView"
             Title="Nova Figurinha"
             BackgroundColor="#F4F4F9">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="Cadastro de Figurinha" FontSize="26" HorizontalTextAlignment="Center" TextColor="#8A1538" FontAttributes="Bold" Margin="0,0,0,15"/>

            <Label Text="Nome do Jogador:" FontAttributes="Bold" TextColor="#1F1F1F"/>
            <Entry x:Name="txtNome" Placeholder="Ex: Vini Jr." PlaceholderColor="Gray" TextColor="Black" BackgroundColor="White"/>

            <Label Text="Seleção:" FontAttributes="Bold" TextColor="#1F1F1F"/>
            <Entry x:Name="txtSelecao" Placeholder="Ex: Brasil" PlaceholderColor="Gray" TextColor="Black" BackgroundColor="White"/>

            <Label Text="Tipo de Figurinha:" FontAttributes="Bold" TextColor="#1F1F1F"/>
            <Picker x:Name="pckTipo" Title="Selecione o tipo" TitleColor="Gray" TextColor="Black" BackgroundColor="White">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Comum</x:String>
                        <x:String>Especial</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <HorizontalStackLayout Spacing="30" HorizontalOptions="Center" Margin="0,10,0,10">
                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                    <Label Text="Obtido:" VerticalOptions="Center" FontAttributes="Bold" TextColor="#1F1F1F"/>
                    <Switch x:Name="swtObtido" ThumbColor="#8A1538" OnColor="#28A745"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                    <Label Text="Desejado:" VerticalOptions="Center" FontAttributes="Bold" TextColor="#1F1F1F"/>
                    <Switch x:Name="swtDesejado" ThumbColor="#8A1538" OnColor="#28A745"/>
                </HorizontalStackLayout>
            </HorizontalStackLayout>

            <Label Text="Foto da Figurinha:" FontAttributes="Bold" TextColor="#1F1F1F"/>
            <Image x:Name="imgCadastro" MaximumHeightRequest="250" MaximumWidthRequest="250" HorizontalOptions="Center" VerticalOptions="Center"/>

            <Button Text="📷 Adicionar Imagem" Clicked="btnAdcionarImagem_Clicked" BackgroundColor="#007ACC" TextColor="White" CornerRadius="8"/>
            <Button Text="❌ Remover Imagem" Clicked="btnRemoverImagem_Clicked" IsVisible="False" x:Name="btnRemoverImagem" BackgroundColor="#DC143C" TextColor="White" CornerRadius="8"/>

            <Button Text="Salvar Registro" Clicked="btnSalvar_Clicked" BackgroundColor="#28A745" TextColor="White" FontAttributes="Bold" CornerRadius="8" Margin="0,20,0,0"/>
            <Button Text="Voltar" Clicked="btnVoltar_Clicked" BackgroundColor="#6C757D" TextColor="White" CornerRadius="8"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>